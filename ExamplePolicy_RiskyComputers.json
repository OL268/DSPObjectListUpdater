    { "Attribute": "description",     "Operator": "-ne",       "Value": "approved-exception" }
  ],
  "Logic": "AND",
  "Scope": {
    "Domains": [ "d01.lab" ],
    "Exclude": [
      { "Domain": "d01.lab", "BaseDN": "OU=Archive,DC=d01,DC=lab" }
    ]
  },
  "Schedule": { "Frequency": "Daily", "TimeUTC": "02:10" }
}
