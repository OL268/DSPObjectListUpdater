{
  "TaskName": "DSPUpdater_RiskyComputers",
  "ListName": "RiskyComputers",
  "Classes": ["Computers"],
  "Filters": [
    { "Attribute": "objectClass",     "Operator": "-eq",       "Value": "computer" },
    { "Attribute": "operatingSystem", "Operator": "-like",     "Value": "*Windows 7*" },
    { "Attribute": "name",            "Operator": "-startswith","Value": "temp-" },
